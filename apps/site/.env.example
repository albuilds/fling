APP_BASE_URL=http://localhost:3000
MAX_UPLOAD_BYTES=104857600

POSTGRES_DB=fling
POSTGRES_USER=<postgres-user>
POSTGRES_PASSWORD=<postgres-password>
DATABASE_URL=postgres://<postgres-user>:<postgres-password>@localhost:5432/fling

FLING_DEV_ACCOUNT_EMAIL=dev@fling.local
FLING_DEV_DEVICE_TOKEN=<dev-device-token>

S3_ENDPOINT=https://s3.<region>.backblazeb2.com
S3_REGION=<region>
S3_BUCKET=<bucket-name>
S3_ACCESS_KEY_ID=<application-key-id>
S3_SECRET_ACCESS_KEY=<application-key>
S3_FORCE_PATH_STYLE=true
